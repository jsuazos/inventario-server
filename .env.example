# Puerto del servidor
PORT=3000

# Supabase (reemplaza Google Sheets para inventario, wishlist y push)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key

# JWT para autenticación
JWT_SECRET=genera-un-secreto-seguro
USUARIOS_JSON=[{"usuario":"jsuazo","hash":"$2b$10$..."}]

# VAPID para Web Push
VAPID_PUBLIC_KEY=tu-clave-publica
VAPID_PRIVATE_KEY=tu-clave-privada

# Google Apps Script (solo para endpoint /api/artistas)
SECRET_TOKEN_INVENTARIO=token-de-google-apps-script

# APIs externas
DISCOGS_TOKEN=tu-token-discogs
FANART_API_KEY=tu-api-key-fanart

# Config
POLL_INTERVAL_MS=600000
ALLOWED_PUBLIC_ORIGINS=https://usuario.github.io,http://localhost:5173,tusitio.com
